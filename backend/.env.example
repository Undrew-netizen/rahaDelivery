DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.yourdomain.com,localhost,127.0.0.1
FRONTEND_ORIGIN=https://www.yourdomain.com
FRONTEND_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
DATABASE_URL=postgresql://postgres:password@localhost:5432/raha_delivery
DB_SSLMODE=require

DEFAULT_FROM_EMAIL=deliveryraha@gmail.com
DELIVERY_NOTIFICATION_EMAIL=deliveryraha@gmail.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=deliveryraha@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True

OTP_EXPIRY_MINUTES=10
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
